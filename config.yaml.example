server:
  port: 8080
  mode: release

webhook:
  secret: "your-webhook-secret"

logging:
  level: "info"
  format: "json"

smtp:
  host: "smtp.example.com"
  port: 587
  username: "noreply@example.com"
  password: "smtp-password"
  from: "noreply@example.com"
  to:
    - "admin@example.com"

api:
  base_url: "http://localhost:3000"
  token: "your-bearer-token"
  timeout: 30
